<Window x:Class="PipeJikkenWPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PipeJikkenWPF"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800"
        Closing="Window_Closing">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Center">
            <TextBlock Text="パイプ名:" VerticalAlignment="Center" Margin="5"/>
            <TextBox x:Name="PipeNameTextBox" Text="ServiceJikkenPipe" Width="200" Margin="5"/>
        </StackPanel>
        
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center">
            <Button Content="サーバー起動" Click="Button_Click" Width="300"/>
            <Button Content="サーバー終了" Click="Button_Click_3" Width="300"/>
            <CheckBox Name="ResponseCheck" Content="Response" IsChecked="True"/>
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center">
            <TextBox x:Name="SendData" Text="SoushinData" Width="300"/>
            <Button Content="クライアント作成" Click="Button_Click_2" />
            <Button Content="クライアントで送信" Click="Button_Click_1" />
            <Button Content="クライアント終了" Click="Button_Click_4" />
        </StackPanel>

        <ListBox Grid.Row="3" x:Name="DataList"/>
    </Grid>
</Window>
